# ============================================================
# API Keys — Copy this file as .env and fill in your real keys
# ============================================================
# cp .env.example .env

# Google Gemini
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_API_KEY_2=your_google_api_key_2_here
GOOGLE_API_KEY_3=your_google_api_key_3_here
GOOGLE_API_KEY_4=your_google_api_key_4_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_KEY_2=your_openai_api_key_2_here
OPENAI_API_KEY_3=your_openai_api_key_3_here

# Mistral
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_API_KEY_2=your_mistral_api_key_2_here
MISTRAL_API_KEY_3=your_mistral_api_key_3_here

# Groq (Llama)
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_KEY_2=your_groq_api_key_2_here

# Flask
FLASK_SECRET_KEY=your_flask_secret_key_here
FLASK_DEBUG=False
